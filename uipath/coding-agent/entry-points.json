{
  "$schema": "https://cloud.uipath.com/draft/2024-12/entry-point",
  "$id": "entry-points.json",
  "entryPoints": [
    {
      "filePath": "main",
      "uniqueId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "type": "function",
      "input": {
        "type": "object",
        "properties": {
          "file_path": {
            "description": "Relative path of the file to fix",
            "type": "string"
          },
          "file_content": {
            "description": "Full content of the file to fix",
            "type": "string"
          },
          "finding": {
            "description": "The finding to fix",
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "severity": { "type": "string" },
              "file": { "type": "string" },
              "root_cause": { "type": "string" },
              "known_facts": { "type": "array", "items": { "type": "string" } },
              "description": { "type": "string" }
            }
          }
        },
        "required": ["file_path", "file_content", "finding"]
      },
      "output": {
        "type": "object",
        "properties": {
          "fixed_content": { "type": "string" },
          "summary": { "type": "string" },
          "confidence": { "type": "number" },
          "success": { "type": "boolean" },
          "method": { "type": "string" }
        },
        "required": ["fixed_content", "success", "method"]
      }
    }
  ]
}