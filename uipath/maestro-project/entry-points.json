{
  "$schema": "https://cloud.uipath.com/draft/2024-12/entry-point",
  "$id": "entry-points.json",
  "entryPoints": [
    {
      "filePath": "orchestration.bpmn",
      "uniqueId": "Event_start",
      "type": "event",
      "input": {
        "type": "object",
        "properties": {
          "executionType": {
            "type": "string",
            "enum": ["agent", "workflow", "api_workflow", "connector"],
            "default": "agent"
          },
          "tenant": {
            "type": "string",
            "default": "Default"
          },
          "taskRef": {
            "type": "string",
            "description": "Maestro task reference ID"
          },
          "entryPoint": {
            "type": "string",
            "default": "main"
          },
          "requestId": {
            "type": "string",
            "description": "Unique request ID for correlation"
          },
          "caseId": {
            "type": "string",
            "description": "Case ID for case-oriented orchestration"
          },
          "payload": {
            "type": "object",
            "description": "Business payload"
          },
          "callbackUrl": {
            "type": "string",
            "description": "Webhook URL for async completion"
          }
        },
        "required": ["taskRef", "requestId"]
      },
      "output": {
        "type": "object",
        "properties": {
          "executionId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["accepted", "queued", "running", "succeeded", "failed", "cancelled"]
          },
          "result": {
            "type": "object",
            "properties": {
              "payload": { "type": "object" },
              "artifacts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "contentType": { "type": "string" },
                    "url": { "type": "string" }
                  }
                }
              }
            }
          },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "retryable": { "type": "boolean" }
            }
          }
        },
        "required": ["executionId", "status"]
      }
    }
  ]
}
